          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"clientName\": \"{{clientName}}\",\n  \"clientEmail\": \"{{clientEmail}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api-clients", "host": ["{{baseUrl}}"], "path": ["api-clients"] }
          }
        }
      ]
