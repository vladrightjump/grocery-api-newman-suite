          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/products?results=-5", "host": ["{{baseUrl}}"], "path": ["products"], "query": [{ "key": "results", "value": "-5" }] } }
        },
        {
          "name": "GET /products?results=abc — non-numeric",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// CONTRACT GAP: docs say results must be numeric, but live API falls back to default and returns 200.",
            "pm.test('200 OK (API tolerates non-numeric)', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/products?results=abc", "host": ["{{baseUrl}}"], "path": ["products"], "query": [{ "key": "results", "value": "abc" }] } }
        }
      ]
