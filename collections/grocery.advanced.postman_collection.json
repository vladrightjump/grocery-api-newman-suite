    {
      "name": "01 Strict Contract",
      "item": [
        {
          "name": "GET /status — strict schema + header",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const schemas = JSON.parse(pm.variables.get('schemas'));",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Content-Type is application/json', () => pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'));",
            "const v = tv4.validate(pm.response.json(), schemas.status, true, true);",
            "pm.test('strict status schema (no extra fields)', () => pm.expect(v, tv4.error && tv4.error.message).to.be.true);"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/status", "host": ["{{baseUrl}}"], "path": ["status"] } }
        },
        {
          "name": "GET /products — strict array schema + header",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const schemas = JSON.parse(pm.variables.get('schemas'));",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Content-Type is application/json', () => pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json'));",
            "const body = pm.response.json();",
            "const v = tv4.validate(body, schemas.productsArray, true, true);",
            "pm.test('strict products schema (banUnknown)', () => pm.expect(v, tv4.error && (tv4.error.message + ' @ ' + tv4.error.dataPath)).to.be.true);",
            "pm.test('every id is a positive integer', () => body.forEach(p => pm.expect(p.id).to.be.a('number').and.to.be.above(0)));",
            "pm.test('every name is non-empty', () => body.forEach(p => pm.expect(p.name).to.be.a('string').and.have.length.above(0)));",
            "const inStock = body.find(p => p.inStock);",
            "if (inStock) pm.collectionVariables.set('productId', inStock.id);"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] } }
        },
        {
          "name": "GET /products/:id — strict product schema",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const schemas = JSON.parse(pm.variables.get('schemas'));",
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const v = tv4.validate(pm.response.json(), schemas.product, true, true);",
            "pm.test('strict product schema', () => pm.expect(v, tv4.error && (tv4.error.message + ' @ ' + tv4.error.dataPath)).to.be.true);"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products", "{{productId}}"] } }
        }
      ]
    },
