    {
      "name": "04 Idempotency & Consistency",
      "item": [
        {
          "name": "Setup: fresh cart + item",
          "event": [{ "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
            "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/carts', method: 'POST' }, (e, r) => {",
            "  const id = r.json().cartId;",
            "  pm.collectionVariables.set('cartId', id);",
            "  pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/carts/' + id + '/items', method: 'POST', header:{'Content-Type':'application/json'}, body:{ mode:'raw', raw: JSON.stringify({ productId: Number(pm.collectionVariables.get('productId')) }) } }, (e2, r2) => {",
            "    pm.collectionVariables.set('itemId', r2.json().itemId);",
            "  });",
            "});"
          ]}},{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('setup ok', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/status", "host": ["{{baseUrl}}"], "path": ["status"] } }
        },
        {
          "name": "PATCH item qty=4 (first call)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 4\n}" },
            "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items", "{{itemId}}"] }
          }
        },
        {
          "name": "PATCH item qty=4 (repeat — idempotent)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 4\n}" },
            "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items", "{{itemId}}"] }
          }
        },
        {
          "name": "GET — qty still 4 after repeated PATCH",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const target = pm.response.json().find(i => String(i.id) === String(pm.collectionVariables.get('itemId')));",
            "pm.test('state stable: qty=4', () => pm.expect(target.quantity).to.eql(4));"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items"] } }
        },
        {
          "name": "Read-after-write: 3 consecutive GETs agree",
          "event": [{ "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
            "// Capture 3 reads in pre-request to detect eventual-consistency drift.",
            "const url = pm.collectionVariables.get('baseUrl') + '/carts/' + pm.collectionVariables.get('cartId') + '/items';",
            "const reads = [];",
            "function go(n){",
            "  if (n === 0) { pm.collectionVariables.set('rawReads', JSON.stringify(reads)); return; }",
            "  pm.sendRequest({ url, method: 'GET' }, (e, r) => { reads.push(r.json()); go(n - 1); });",
            "}",
            "go(3);"
          ]}},{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('this request ok', () => pm.response.to.have.status(200));",
            "const reads = JSON.parse(pm.collectionVariables.get('rawReads') || '[]');",
            "pm.test('3 consecutive reads captured', () => pm.expect(reads).to.have.length(3));",
            "const itemId = String(pm.collectionVariables.get('itemId'));",
            "const qtys = reads.map(arr => { const t = arr.find(i => String(i.id) === itemId); return t && t.quantity; });",
            "pm.test('all 3 reads see qty=4', () => pm.expect(qtys).to.eql([4, 4, 4]));"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items"] } }
        },
        {
          "name": "PUT replace qty=2 (first)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}" },
            "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items", "{{itemId}}"] }
          }
        },
        {
          "name": "PUT replace qty=2 (repeat — idempotent)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}" },
            "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items", "{{itemId}}"] }
          }
        },
        {
          "name": "GET — qty=2 after repeated PUT",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 OK', () => pm.response.to.have.status(200));",
            "const target = pm.response.json().find(i => String(i.id) === String(pm.collectionVariables.get('itemId')));",
            "pm.test('PUT idempotent: qty=2', () => pm.expect(target.quantity).to.eql(2));"
          ]}}],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items"] } }
        },
        {
          "name": "DELETE item",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('204 No Content', () => pm.response.to.have.status(204));"
          ]}}],
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items", "{{itemId}}"] } }
        },
        {
          "name": "DELETE item (repeat — 404 not 204)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// DELETE here is NOT idempotent on status code (returns 404 second time) — pinning observed contract.",
            "pm.test('404 Not Found', () => pm.response.to.have.status(404));"
          ]}}],
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/carts/{{cartId}}/items/{{itemId}}", "host": ["{{baseUrl}}"], "path": ["carts", "{{cartId}}", "items", "{{itemId}}"] } }
        }
      ]
    }
  ]
